generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash    String?
  // Optional per-user Gemini API key, stored encrypted at rest (AES-256-GCM:
  // ciphertext + iv + auth tag) exactly like Plaid tokens. Never returned to
  // the browser; when unset, the server falls back to the shared .env key.
  geminiKeyCiphertext String?
  geminiKeyIv         String?
  geminiKeyAuthTag    String?
  receipts        Receipt[]
  sessions        Session[]
  bankConnections BankConnection[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// A linked bank Item. The Plaid access token is stored encrypted at rest
// (AES-256-GCM: ciphertext + iv + auth tag) and never leaves the server.
// transactionCursor tracks the position of the last /transactions/sync so each
// sync only pulls what changed since the previous one.
model BankConnection {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String        @default("plaid")
  institutionName   String?
  itemId            String?
  encryptedToken    String
  tokenIv           String
  tokenAuthTag      String
  transactionCursor String?
  accounts          BankAccount[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@map("bank_connections")
}

model BankAccount {
  id             String           @id @default(cuid())
  connectionId   String
  connection     BankConnection   @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  plaidAccountId String           @unique
  name           String?
  type           String?
  lastFour       String?
  transactions   BankTransaction[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([connectionId])
  @@map("bank_accounts")
}

model BankTransaction {
  id          String      @id @default(cuid())
  accountId   String
  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plaidTxnId  String      @unique
  date        DateTime
  description String?
  amount      Decimal     @db.Decimal(10, 2)
  category    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([accountId])
  @@map("bank_transactions")
}

model Receipt {
  id            String       @id @default(cuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  storeName     String?
  receiptDate   DateTime?
  receiptNumber String?
  category      String      @default("Other")
  subtotal      Decimal?    @db.Decimal(10, 2)
  tax           Decimal?    @db.Decimal(10, 2)
  total         Decimal?    @db.Decimal(10, 2)
  ocrProvider   String?
  ocrConfidence Decimal?    @db.Decimal(5, 2)
  rawOcrText    String?
  ocrDocument   Json?
  imageUrl      String?
  lines         ReceiptLine[]
  people        Person[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("receipts")
}

model ReceiptLine {
  id          String           @id @default(cuid())
  receiptId   String
  receipt     Receipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  label       String
  amount      Decimal          @db.Decimal(10, 2)
  confidence  Decimal?         @db.Decimal(5, 2)
  ignored     Boolean          @default(false)
  ocrLineId   String?
  boundingBox Json?
  sortOrder   Int              @default(0)
  assignments LineAssignment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("receipt_lines")
}

model Person {
  id          String           @id @default(cuid())
  receiptId   String
  receipt     Receipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  name        String
  assignments LineAssignment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("people")
}

model LineAssignment {
  id        String      @id @default(cuid())
  lineId    String
  line      ReceiptLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  personId  String
  person    Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  mode      String      @default("equal")
  value     Decimal     @default(0) @db.Decimal(10, 2)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("line_assignments")
}
