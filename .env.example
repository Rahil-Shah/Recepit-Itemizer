# Rename this file to .env and fill in your own values.

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Server ---
PORT=4173
# Set when running behind a reverse proxy (nginx, a PaaS load balancer, ...) so
# the client IP used for rate limiting is read from X-Forwarded-For. Use "true"
# or a trusted hop count (e.g. "1"). Leave unset when directly exposed.
TRUST_PROXY=

# --- Auth & secret storage ---
# Random secret used to sign/verify session material. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SESSION_SECRET=your_random_session_secret_here
# 32-byte base64 key used to AES-256-GCM encrypt Plaid access tokens at rest.
# Generate with the same command as above. Keep this stable — rotating it makes
# existing encrypted tokens undecryptable (users must reconnect their bank).
TOKEN_ENCRYPTION_KEY=your_base64_32_byte_key_here

# --- Plaid (read-only bank connection) ---
# "sandbox" uses fake credentials/data. Switch to "development" or "production"
# (real banks) by changing PLAID_ENV and using the matching secret — no code
# change required. Get your keys from the Plaid dashboard.
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# --- Database ---
# Matches the local Postgres started by `npm run db:up` (docker-compose.yml).
# To scale, point this at a managed Postgres (Neon, Supabase, RDS, ...) — no code changes needed.
DATABASE_URL="postgresql://receipt:receipt@localhost:5433/receipt_ring?schema=public"
