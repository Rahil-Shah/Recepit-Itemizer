# Rename this file to .env and fill in your own values.

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Server ---
PORT=4173

# --- Auth & secret storage ---
# Random secret used to sign/verify session material. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SESSION_SECRET=your_random_session_secret_here
# 32-byte base64 key used to AES-256-GCM encrypt Teller access tokens at rest.
# Generate with the same command as above. Keep this stable — rotating it makes
# existing encrypted tokens undecryptable (users must reconnect their bank).
TOKEN_ENCRYPTION_KEY=your_base64_32_byte_key_here

# --- Teller (read-only bank connection) ---
# "sandbox" uses fake data and needs no client certificate.
# Switch to "development" (real banks) by setting the two cert paths below —
# no code change required.
TELLER_ENVIRONMENT=sandbox
TELLER_APPLICATION_ID=your_teller_application_id_here
# Only needed for development/production. Download from the Teller dashboard and
# store them under ./certs/ (gitignored). Leave blank for sandbox.
TELLER_CERT_PATH=
TELLER_KEY_PATH=

# --- Database ---
# Matches the local Postgres started by `npm run db:up` (docker-compose.yml).
# To scale, point this at a managed Postgres (Neon, Supabase, RDS, ...) — no code changes needed.
DATABASE_URL="postgresql://receipt:receipt@localhost:5433/receipt_ring?schema=public"
